# ══════════════════════════════════════════════════════════════════════════════
#  ARVEN PARFUM — Environment Configuration Template
#  Salin file ini menjadi .env lalu isi nilainya sesuai lingkungan Anda.
#  JANGAN pernah commit file .env ke version control (sudah ada di .gitignore).
# ══════════════════════════════════════════════════════════════════════════════

# ─── Aplikasi ────────────────────────────────────────────────────────────────
APP_NAME="Arven Parfum"
APP_ENV=local                    # local | staging | production
APP_KEY=                         # Generate dengan: php artisan key:generate
APP_DEBUG=true                   # Set ke false di production!
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

# ─── Maintenance Mode ─────────────────────────────────────────────────────────
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12                 # Naikkan ke 14 di production untuk keamanan lebih

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                  # Set ke "error" di production

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=arven_parfum
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120             # Durasi sesi dalam menit
SESSION_ENCRYPT=false            # Set ke true di production
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Cache ────────────────────────────────────────────────────────────────────
CACHE_STORE=database
CACHE_PREFIX=arven_cache_

# ─── Queue ────────────────────────────────────────────────────────────────────
# Ganti ke "database" atau "redis" jika menggunakan job queue untuk email pesanan
QUEUE_CONNECTION=sync

# ─── Filesystem ───────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ─── Broadcasting ─────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ─── Mail / Notifikasi Pesanan ────────────────────────────────────────────────
# Konfigurasi ini WAJIB diisi agar notifikasi email pesanan dan kontak berfungsi.
#
# Untuk development: gunakan Mailtrap (https://mailtrap.io) atau Mailpit
# Untuk production : gunakan SMTP Gmail, Mailgun, Resend, dsb.
#
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io  # Ganti dengan SMTP provider Anda
MAIL_PORT=2525                       # Gmail: 587 | SSL: 465
MAIL_USERNAME=                       # Username SMTP Anda
MAIL_PASSWORD=                       # Password SMTP Anda
MAIL_ENCRYPTION=tls                  # tls | ssl | null
MAIL_FROM_ADDRESS="noreply@arvenparfum.com"
MAIL_FROM_NAME="Arven Parfum"

# Email admin yang menerima notifikasi pesan kontak & pesanan baru
MAIL_ADMIN_EMAIL=admin@arvenparfum.com

# ─── Redis (Opsional — aktifkan jika pakai Redis untuk cache/queue) ────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── AWS S3 (Opsional — aktifkan jika menyimpan foto produk di cloud) ─────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=arven-parfum-assets
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Vite (Frontend Build) ────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"

# ─── Rate Limiting (Login Throttle) ──────────────────────────────────────────
# Diatur langsung di routes/web.php (throttle:5,1).
# Tidak perlu mengubah variabel ini secara manual.

# ─── Pengaturan Toko Parfum ───────────────────────────────────────────────────
# Tambahkan variabel kustom bisnis Anda di sini
STORE_NAME="Arven Parfum"
STORE_PHONE="+62 812-3456-7890"
STORE_ADDRESS="Surabaya, Jawa Timur, Indonesia"
STORE_INSTAGRAM="@arvenparfum"
STORE_CURRENCY=IDR
STORE_CURRENCY_SYMBOL=Rp
